# CrowdWisdomQuant — environment variable reference
#
# Copy this file to .env and fill in your values.
# All variables use the CROWDWISDOM_ prefix.

# --- Database ---
# Default: sqlite:///data/database/crowdwisdom.db
# For PostgreSQL: CROWDWISDOM_DATABASE_URL=postgresql://user:pass@host:5432/crowdwisdom
# CROWDWISDOM_DATABASE_URL=

# --- Apify (macro scraper) ---
# Get your API key at https://console.apify.com
# APIFY_API_KEY=your_key_here

# --- Logging ---
# CROWDWISDOM_LOG_LEVEL=DEBUG
# CROWDWISDOM_LOG_FILE=logs/crowdwisdom.log
